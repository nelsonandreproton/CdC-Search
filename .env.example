# ============================================================================
# CdC-Search — configuração
# Copia este ficheiro para .env e preenche os valores.
# NUNCA faças commit do .env (está no .gitignore).
# ============================================================================

# --- Localização-alvo: Casal de Cambra (Sintra) ---------------------------
TARGET_NAME="Casal de Cambra"
TARGET_LATITUDE=38.7995
TARGET_LONGITUDE=-9.2330
# Raio (em metros) à volta do ponto acima onde procuramos empresas.
TARGET_RADIUS_M=2500
TARGET_REGION_CODE=PT
TARGET_LANGUAGE=pt-PT

# --- Google Places API (New) ----------------------------------------------
# Cria uma chave em https://console.cloud.google.com (ativa "Places API (New)").
# Restringe a chave por API e, idealmente, por IP do servidor Hetzner.
GOOGLE_MAPS_API_KEY=""

# --- LLM Gateway (free-llm-gateway) ---------------------------------------
# O gateway corre na rede interna do Docker; não o exponhas à internet.
LLM_GATEWAY_URL="http://gateway:8080/v1"
# Tem de ser IGUAL ao MASTER_KEY definido em gateway/.env.
LLM_GATEWAY_API_KEY="change-me-internal-key"
# Nome lógico do modelo no gateway (ver models.yaml / GET /v1/models).
# "llama-3.3-70b" é servido por Groq e NVIDIA NIM via cadeia de fallback.
LLM_MODEL="llama-3.3-70b"
# Se "false", o pipeline nunca chama o LLM (usa só o mapeamento da Google).
LLM_ENABLED=true

# --- racius.com (enriquecimento, best-effort) -----------------------------
# Scraping respeitoso e opcional; pode falhar se o site bloquear.
RACIUS_ENABLED=true
RACIUS_REQUEST_DELAY_S=3.0

# --- Base de dados ---------------------------------------------------------
DATABASE_URL="sqlite:////data/cdc.sqlite3"

# --- Web -------------------------------------------------------------------
SITE_NAME="Diretório de Casal de Cambra"
SITE_BASE_URL="https://example.com"

# --- Admin -----------------------------------------------------------------
# Token para o painel /admin e para disparar a recolha manualmente.
# Gera um valor forte (ex.: `openssl rand -hex 24`). Vazio = admin desativado.
ADMIN_TOKEN=""
