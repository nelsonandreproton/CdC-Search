# ============================================================================
# Configuração do free-llm-gateway (Groq + NVIDIA NIM).
#
# Depois de clonar o gateway:
#     git clone https://github.com/MrFadiAi/free-llm-gateway.git gateway
# copia este ficheiro para gateway/.env e preenche as chaves:
#     cp deploy/gateway.env.example gateway/.env
# ============================================================================

# Chave do próprio gateway. TEM de ser igual a LLM_GATEWAY_API_KEY no .env raiz.
MASTER_KEY="change-me-internal-key"

# O serviço escuta dentro da rede do Docker (não exposto à internet).
HOST="0.0.0.0"
PORT="8080"

# --- Providers (as tuas chaves) -------------------------------------------
GROQ_KEY="cola-aqui-a-tua-chave-groq"
NVIDIA_NIM_KEY="cola-aqui-a-tua-chave-nvidia-nim"

# Nota: confirma em gateway/models.yaml que o modelo "llama-3.3-70b" tem uma
# cadeia de fallback que inclui groq e nvidia. Exemplo:
#   models:
#     llama-3.3-70b:
#       - provider: groq
#         model: llama-3.3-70b-versatile
#       - provider: nvidia
#         model: meta/llama-3.1-70b-instruct
